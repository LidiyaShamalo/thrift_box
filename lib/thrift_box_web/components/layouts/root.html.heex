
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="ThriftBox">
      {assigns[:page_title]}
    </.live_title>
    <%!-- Подключение стилей и скриптов --%>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
  </head>
  <body class="bg-base-100 antialiased">
  
    <header style="display: flex; justify-content: space-between; padding: 20px; border-bottom: 2px solid red; background: white;">
  <div style="font-weight: bold; color: black;">
    <.link navigate={~p"/"}>HOME (ThriftBox)</.link>
  </div>

  <nav style="background: #eee; padding: 10px; display: flex; gap: 20px;">
  <%!-- ТЕСТ 1: Просто текст (должен быть виден всегда) --%>
  <span style="color: red; font-weight: bold;">ТЕСТ КНОПОК:</span>

  <%!-- ТЕСТ 2: Прямые ссылки без всяких IF --%>
  <.link navigate={~p"/users/register"} style="color: blue; text-decoration: underline;">РЕГИСТРАЦИЯ</.link>
  <.link navigate={~p"/users/log-in"} style="color: blue; text-decoration: underline;">ВХОД</.link>
  <.link navigate={~p"/users/settings"} style="color: green; text-decoration: underline;">НАСТРОЙКИ</.link>
  
  <%!-- ТЕСТ 3: Попытка вывести имя Боба напрямую из твоего лога --%>
  <span style="color: black;">
    ИМЯ ИЗ ЛОГА: 
    <%= if assigns[:current_scope], do: assigns[:current_scope].user.name, else: "НЕТ ДАННЫХ" %>
  </span>
</nav>
</header>

    <%!-- Сюда вставляется контент страниц --%>
    {@inner_content}
  </body>
</html>